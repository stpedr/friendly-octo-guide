# Contexto de build = raiz do repo (o CI chama: docker build -f src/Ai/Dockerfile.worker-vision .)
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src
COPY Directory.Build.props ./
COPY src/Platform/ src/Platform/
COPY src/Ai/ src/Ai/
RUN dotnet publish src/Ai/Ai.Worker.Vision -c Release -o /app

FROM mcr.microsoft.com/dotnet/aspnet:10.0
WORKDIR /app
COPY --from=build /app .
USER $APP_UID
ENTRYPOINT ["dotnet", "Ai.Worker.Vision.dll"]
