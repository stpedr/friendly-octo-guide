{
  "Serilog": {
    "MinimumLevel": { "Default": "Information", "Override": { "Microsoft.AspNetCore": "Warning" } }
  },
  "ReverseProxy": {
    "Routes": {
      "auth": {
        "ClusterId": "identity",
        "Match": { "Path": "/v1/auth/{**rest}" }
      },
      "core": {
        "ClusterId": "core",
        "Match": { "Path": "/v1/core/{**rest}" }
      },
      "chat": {
        "ClusterId": "chatbot",
        "Match": { "Path": "/v1/chat/{**rest}" }
      },
      "knowledge": {
        "ClusterId": "knowledge",
        "Match": { "Path": "/v1/knowledge/{**rest}" }
      },
      "agents": {
        "ClusterId": "agents",
        "Match": { "Path": "/v1/agents/{**rest}" }
      }
    },
    "Clusters": {
      "identity": { "Destinations": { "d1": { "Address": "http://identity:8080/" } } },
      "core": { "Destinations": { "d1": { "Address": "http://core-execution:8080/" } } },
      "chatbot": { "Destinations": { "d1": { "Address": "http://chatbot:8080/" } } },
      "knowledge": { "Destinations": { "d1": { "Address": "http://knowledge:8080/" } } },
      "agents": { "Destinations": { "d1": { "Address": "http://agents:8080/" } } }
    }
  }
}
