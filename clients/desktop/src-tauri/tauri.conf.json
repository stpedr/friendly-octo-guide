{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "plataforma-linha",
  "version": "0.1.0",
  "identifier": "com.plataforma-linha.desktop",
  "build": {
    "frontendDist": "../../pwa"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http: https: ws: wss:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.png"]
  }
}
